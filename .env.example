# Required: your Anthropic API key, used server-side only by the
# AI Email Writer tool (app/api/tools/email-writer/generate/route.ts).
# As more AI-powered tools are added to the registry, they'll reuse this
# same key unless a tool specifically needs its own.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: your deployed site URL, used across the platform for SEO
# metadata (Open Graph, JSON-LD, sitemap.xml, robots.txt).
# Defaults to https://toolverse.vercel.app if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
